# このファイルをコピーして .env を作成してください（.env は Git に含めない）。
# cp .env.example .env

# --- Slack（Socket Mode）---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# --- OpenAI（意図解析・音声文字起こし）---
OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o

# --- Google OAuth（プロジェクト直下に credentials.json を配置）---
# 同一マシンのブラウザだけならデフォルトのままでよい。
# OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:8888

# 別端末のブラウザから連携する場合は HTTPS の公開 URL（末尾スラッシュなし）。
# チーム運用では「毎回変わる Quick Tunnel より」固定ホスト（ngrok 予約ドメイン / Cloudflare 名前付きトンネル / VPS 等）を推奨。REMOTE_SETUP.md の「固定 URL」参照。
# OAUTH_PUBLIC_BASE_URL=https://your-fixed-host.example.com
# OAUTH_PUBLIC_BASE_URL=https://xxxx.ngrok-free.app
# OAUTH_PUBLIC_BASE_URL=https://xxxx.trycloudflare.com

# 任意: クライアントシークレットのパス（デフォルトは credentials.json）
# GOOGLE_CREDENTIALS=credentials.json
# CLI 用の単一 token（Slack 連携では data/google_tokens/ を使用）
# GOOGLE_TOKEN=token.json

# --- ngrok 予約ドメイン（dashboard.ngrok.com → Domains で発行したホスト）---
# remote_oauth.sh が --domain に使います。未設定ならランダム URL のトンネルになります。
# NGROK_DOMAIN=your-name.ngrok-free.dev

# --- Google カレンダー（Slack ボット経由）---
# 未設定なら「メッセージ送信者」の Google トークンを使う（kota が送れば kota.n のカレンダーに入る）。
# 常に特定メンバー（例: daisuke）のカレンダーだけに書きたいとき、その人の Slack ユーザー ID を指定する。
# 指定したユーザーは data/google_tokens/<ID>.json で Google 連携済みであること。
# SCHEDULE_FORCE_CALENDAR_SLACK_USER_ID=Uxxxxxxxx

# --- oauth_server（通常は省略可）---
# OAUTH_SERVER_HOST=127.0.0.1
# OAUTH_SERVER_PORT=8888
# iPhone ショートカット POST /api/meet を転送する先（既定: http://127.0.0.1:3847）
# IOS_SHORTCUT_API_BASE=http://127.0.0.1:3847
