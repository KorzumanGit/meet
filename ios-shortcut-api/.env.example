# --- サーバー ---
PORT=3847

# /auth/google がリダイレクトする OAuth サーバー（meet/oauth_server.py、既定 8888）
# OAUTH_SERVER_PUBLIC_URL=http://127.0.0.1:8888
# ngrok 利用時は https://xxxx.ngrok-free.app など（meet/.env の OAUTH_PUBLIC_BASE_URL と揃える）

# /auth/google で slack_user_id を毎回付けずに済ませる場合（任意）
# SLACK_OAUTH_USER_ID=U079BG1BKJ9

# 任意: iOS ショートカットからのリクエストを制限する共有秘密（未設定なら検証しない）
# API_KEY=your-random-secret

# 任意: CORS を特定オリジンのみに制限（カンマ区切り）。未設定のときは全オリジン許可（Origin なしも許可）
# CORS_ORIGINS=https://example.com,capacitor://localhost

# --- Google Calendar / Meet ---
# OAuth2 クライアント（デスクトップまたはウェブ）のクライアント ID / シークレット
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 必須スコープ（認可 URL に含めてリフレッシュトークンを取得）:
#   https://www.googleapis.com/auth/calendar.events
# 初回のみブラウザで認可し、返却されたリフレッシュトークンを保存する。
GOOGLE_REFRESH_TOKEN=

# どの Google アカウントのカレンダーに書くか（必須）。起動時にトークンと一致しないとサーバは起動しない。
GOOGLE_CALENDAR_OWNER_EMAIL=daisuke.k@humbull.co

# ローカル検証のみ（本番では使わない）
# SKIP_GOOGLE_CALENDAR_VERIFY=true

# 上記アカウントのトークンを meet/data/google_tokens/<SlackユーザーID>.json から読む（推奨）
# （その JSON が daisuke.k@humbull.co で OAuth したものであることを確認すること）
# GOOGLE_TOKEN_FILE=../data/google_tokens/Uxxxxxxxx.json

# イベントを作成するカレンダー ID（そのアカウントの primary なら primary またはメールアドレス）
GOOGLE_CALENDAR_ID=primary

# --- Slack 通知 ---
# 既定の投稿先チャンネル: C0AR1VBT3ED（SLACK_CHANNEL_ID で変更可）
#
# メンション付き通知には Bot トークン（chat:write）を推奨。SLACK_BOT_TOKEN があるときは
# Incoming Webhook より chat.postMessage が優先される（Webhook だけだと <@U...> が効かないことがある）。
#
# Incoming Webhook（チャンネル C0AR1VBT3ED 用に発行した URL を設定）
SLACK_WEBHOOK_URL=

# Bot トークン（chat:write 等）。チャンネル未指定時は C0AR1VBT3ED に投稿
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0AR1VBT3ED

# C0AR1VBT3ED への実行結果の先頭メンション（@daisuke_kouzuma）。未設定時はコード既定の U ID → SLACK_OAUTH_USER_ID 等の順で解決
# SLACK_CHANNEL_RESULT_MENTION_USER_ID=Uxxxxxxxx

# 任意: C0AR1VBT3ED 以外の挙動用に別 ID を使う場合（通常は不要）
# SLACK_SHORTCUT_NOTIFY_USER_ID=Uxxxxxxxx
